<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="general" title="Configuración e-CF" numcolumns="12">
            <column name="activo" numcolumns="2" order="100">
                <widget type="checkbox" fieldname="activo"/>
            </column>
            <column name="ambiente" numcolumns="4" order="110">
                <widget type="select" fieldname="ambiente">
                    <values title="TesteCF" ref="TesteCF"/>
                    <values title="eCF (Producción)" ref="eCF"/>
                </widget>
            </column>
            <column name="rnc-emisor" title="RNC Emisor" numcolumns="2" order="120">
                <widget type="text" fieldname="rnc_emisor" icon="fa-solid fa-id-card"/>
            </column>
            <column name="razon-social" title="Razón Social" numcolumns="4" order="130">
                <widget type="text" fieldname="razon_social" icon="fa-solid fa-building"/>
            </column>
        </group>
        <group name="certificado" title="Certificado Digital" numcolumns="12">
            <column name="ruta-cert" title="Ruta Certificado Digital .p12" numcolumns="8" order="100">
                <widget type="text" fieldname="ruta_certificado_p12" icon="fa-solid fa-file-certificate" readonly="true"/>
            </column>
            <column name="pass-cert" title="Password Certificado" numcolumns="4" order="110">
                <widget type="password" fieldname="password_certificado"/>
            </column>
        </group>
        <group name="info-cert" title="Información del Certificado" numcolumns="12">
            <column name="cert-sujeto" title="Titular (CN)" numcolumns="6" order="100">
                <widget type="text" fieldname="cert_sujeto" icon="fa-solid fa-user-shield" readonly="true"/>
            </column>
            <column name="cert-emisor" title="Emisor" numcolumns="6" order="110">
                <widget type="text" fieldname="cert_emisor" icon="fa-solid fa-building" readonly="true"/>
            </column>
            <column name="cert-vencimiento" title="Fecha de Vencimiento" numcolumns="4" order="120">
                <widget type="date" fieldname="cert_vencimiento" icon="fa-solid fa-calendar-xmark" readonly="true"/>
            </column>
        </group>
    </columns>
    <rows>
        <row type="footer">
            <group name="footer-actions" footer="specials-actions">
                <button name="btn_test_conexion" title="Probar Conexión con DGII" icon="fa-solid fa-plug" action="test-conexion" color="primary"/>
            </group>
        </row>
    </rows>
    <modals>
        <group name="upload-cert" title="Subir Certificado Digital .p12" icon="fas fa-upload">
            <column name="cert-file" title="Seleccionar archivo .p12" numcolumns="12">
                <widget type="file" fieldname="cert_file" accept=".p12" required="true"/>
            </column>
        </group>
        <group name="verify-cert" title="Verificar Contraseña del Certificado" icon="fas fa-key">
            <column name="verify-password" title="Contraseña del certificado .p12" numcolumns="12">
                <widget type="password" fieldname="verify_password" required="true"/>
            </column>
            <column name="btn-verify" numcolumns="12">
                <widget type="button" fieldname="btn_verify" label="Verificar" action="verify-cert" color="primary"/>
            </column>
        </group>
    </modals>
</view>
