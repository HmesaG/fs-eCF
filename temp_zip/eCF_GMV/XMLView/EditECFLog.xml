<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="general" title="Detalles del Envío" numcolumns="12">
            <column name="id" numcolumns="2" order="100">
                <widget type="number" fieldname="id" icon="fa-solid fa-hashtag" readonly="dinamic"/>
            </column>
            <column name="fecha" numcolumns="4" order="110">
                <widget type="datetime" fieldname="fecha" readonly="true"/>
            </column>
            <column name="tipo" numcolumns="3" order="120">
                <widget type="text" fieldname="tipo" readonly="true"/>
            </column>
            <column name="http-code" title="HTTP Code" numcolumns="2" order="130">
                <widget type="number" fieldname="http_code" readonly="true"/>
            </column>
            <column name="referencia" numcolumns="6" order="140">
                <widget type="text" fieldname="referencia" readonly="true"/>
            </column>
        </group>
    </columns>
    <tabs>
        <tab name="tab_original" title="XML Sin Firma">
            <columns>
                <group name="group_original" numcolumns="12">
                    <column name="xml_sin_firma" numcolumns="12" order="100">
                        <widget type="textarea" fieldname="xml_sin_firma" readonly="true"/>
                    </column>
                </group>
            </columns>
        </tab>
        <tab name="tab_firmado" title="XML Firmado">
            <columns>
                <group name="group_firmado" numcolumns="12">
                    <column name="xml_firmado" numcolumns="12" order="100">
                        <widget type="textarea" fieldname="xml_firmado" readonly="true"/>
                    </column>
                </group>
            </columns>
        </tab>
        <tab name="tab_respuesta" title="Respuesta DGII">
            <columns>
                <group name="group_respuesta" numcolumns="12">
                    <column name="respuesta" numcolumns="12" order="100">
                        <widget type="textarea" fieldname="respuesta" readonly="true"/>
                    </column>
                </group>
            </columns>
        </tab>
    </tabs>
</view>
